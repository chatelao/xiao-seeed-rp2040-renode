$global.TEST_FILE=$ORIGIN/../../../pico-examples/build/i2c/pa1010d_i2c/pa1010d_i2c.elf

$machine_name="pico_tests"
path add $ORIGIN/../..
include $ORIGIN/../../../../cores/initialize_peripherals.resc
machine LoadPlatformDescription $ORIGIN/raspberry_pico_with_pa1010d.repl
sysbus LoadELF $ORIGIN/../../../../bootroms/rp2040/b2.elf

include $ORIGIN/../../../testers/load_testers.resc

# Configure PA1010D GPS module with test values
log "Configuring PA1010D GPS values"

# Test 1: Valid GPS data (London coordinates approximately)
sysbus.i2c0.pa1010d SetUtcTime "123519.00"
sysbus.i2c0.pa1010d SetDataValid
sysbus.i2c0.pa1010d SetLatitude "4807.038"
sysbus.i2c0.pa1010d SetNsIndicator "N"
sysbus.i2c0.pa1010d SetLongitude "01131.000"
sysbus.i2c0.pa1010d SetEwIndicator "E"
sysbus.i2c0.pa1010d SetSpeedOverGround "022.4"
sysbus.i2c0.pa1010d SetCourseOverGround "084.4"
sysbus.i2c0.pa1010d SetDate "230394"

log "Loading firmware file"
sysbus LoadELF $global.TEST_FILE

sysbus.cpu0 VectorTableOffset 0x00000000
sysbus.cpu1 VectorTableOffset 0x00000000

showAnalyzer sysbus.uart0
