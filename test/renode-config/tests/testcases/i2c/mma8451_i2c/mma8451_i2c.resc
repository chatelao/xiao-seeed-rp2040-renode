$global.TEST_FILE=$ORIGIN/../../../pico-examples/build/i2c/mma8451_i2c/mma8451_i2c.elf

$machine_name="pico_tests"
path add $ORIGIN/../..
include $ORIGIN/../../../../cores/initialize_peripherals.resc
machine LoadPlatformDescription $ORIGIN/raspberry_pico_with_mma8451.repl
sysbus LoadELF $ORIGIN/../../../../bootroms/rp2040/b2.elf

include $ORIGIN/../../../testers/load_testers.resc

# Configure MMA8451 accelerometer with test values
log "Configuring MMA8451 accelerometer values"

# Test 1: Device at rest (Z = 1g, X = Y = 0g)
sysbus.i2c0.mma8451 SetAcceleration 0.0 0.0 1.0

log "Loading firmware file"
sysbus LoadELF $global.TEST_FILE

sysbus.cpu0 VectorTableOffset 0x00000000
sysbus.cpu1 VectorTableOffset 0x00000000

showAnalyzer sysbus.uart0
