diff --git a/adc/dma_capture/dma_capture.c b/adc/dma_capture/dma_capture.c
index a0e947c..fbd3920 100644
--- a/adc/dma_capture/dma_capture.c
+++ b/adc/dma_capture/dma_capture.c
@@ -69,7 +69,7 @@ int main() {
     adc_set_clkdiv(0);

     printf("Arming DMA\n");
-    sleep_ms(1000);
+    sleep_ms(100);
     // Set up the DMA to start transferring data as soon as it appears in FIFO
     uint dma_chan = dma_claim_unused_channel(true);
     dma_channel_config cfg = dma_channel_get_default_config(dma_chan);
diff --git a/adc/hello_adc/hello_adc.c b/adc/hello_adc/hello_adc.c
index 9eeb455..44e2428 100644
--- a/adc/hello_adc/hello_adc.c
+++ b/adc/hello_adc/hello_adc.c
@@ -25,6 +25,6 @@ int main() {
         const float conversion_factor = 3.3f / (1 << 12);
         uint16_t result = adc_read();
         printf("Raw value: 0x%03x, voltage: %f V\n", result, result * conversion_factor);
-        sleep_ms(500);
+        sleep_ms(50);
     }
 }
