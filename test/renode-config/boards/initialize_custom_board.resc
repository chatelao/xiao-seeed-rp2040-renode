mach create $machine_name

# Compile from source (development mode - slower but allows live editing)
# For production mode (pre-built DLL), use initialize_peripherals.resc instead
include $ORIGIN/../cores/initialize_peripherals_source.resc
machine LoadPlatformDescription $platform_file
sysbus LoadELF $ORIGIN/../bootroms/rp2040/b2.elf
